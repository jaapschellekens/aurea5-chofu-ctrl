#pragma once

// WiFi
const char* SSID        = "jouw-netwerk";
const char* PASS        = "jouw-wachtwoord";

// MQTT
const char* MQTT_BROKER = "192.168.1.x";
const int   MQTT_PORT   = 1883;
const char* MQTT_USER   = "";   // leeg als geen auth
const char* MQTT_PASS   = "";

// MQTT topic-prefix / HA-device: zie MQTT_PREFIX / HA_NODE / HA_DEV_NAME in
// types.h. Pas die aan voor een testbord (bv. "chofu_test") zodat het
// productiesysteem en zijn HA-entiteiten niet overschreven worden.

// ── ESP32 specifiek ─────────────────────────────────────────────
// Standaard CHOFU_RX_PIN=16, CHOFU_TX_PIN=17 (zie chofu_wp_ff.ino).
// Overschrijf hier als jouw board andere pinnen gebruikt:
// #define CHOFU_RX_PIN 16
// #define CHOFU_TX_PIN 17
//
// LCD I2C: op ESP32 zijn SDA=21, SCL=22 de standaard Wire-pinnen.
// Afwijkend board: voeg Wire.begin(SDA, SCL) toe in setup() vóór lcd.init().

// ── Plugwise Adam directe integratie (optioneel) ────────────────
// Zet USE_ADAM op 1 om setpoints/temperaturen direct uit de Plugwise Adam
// te halen i.p.v. via Home Assistant (MQTT). Default 0 = uit: de hele Adam-laag
// blijft dan inert en het gedrag is identiek aan een build zonder Adam.
//
// De bron is daarnaast runtime schakelbaar via MQTT (chofu/cmd/bron = mqtt|adam);
// 'adam' wordt alleen geaccepteerd in de ff_water-modus. MQTT blijft de default.
//
// Zonenamen exact zoals ze in de Adam staan (achterhaal met adam_discover.py).
// De leidende zone (grootste warmtevraag) bepaalt t_kamer; volgorde hieronder
// dient enkel als tie-break.
#define USE_ADAM       0
#if USE_ADAM
  #define ADAM_IP      "192.168.1.x"
  #define ADAM_PASS    "smile-ww"               // 8 tekens van de sticker
  #define ADAM_ZONES   {"Woonkamer", "Studeer"} // pas aan per installatie
#endif
